<?xml version="1.0" encoding="UTF-8"?>

<Configuration status="WARN">

    <!-- ============================================================
         PROPERTIES
         ============================================================ -->
    <Properties>
        <Property name="LOG_PATTERN">
            %d{yyyy-MM-dd HH:mm:ss} [%t] %-5level %logger{1} - %msg%n
        </Property>
        <Property name="LOG_PATH">logs</Property>
    </Properties>


    <!-- ============================================================
         APPENDERS
         ============================================================ -->
    <Appenders>

        <!-- Console Logs -->
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${LOG_PATTERN}"/>
        </Console>

        <!-- Rolling File Logs -->
        <RollingFile name="File"
                     fileName="${LOG_PATH}/application-service.log"
                     filePattern="${LOG_PATH}/application-service-%d{yyyy-MM-dd}-%i.log.gz">

            <PatternLayout pattern="${LOG_PATTERN}"/>

            <Policies>
                <TimeBasedTriggeringPolicy interval="1"/>
                <SizeBasedTriggeringPolicy size="10MB"/>
            </Policies>

            <DefaultRolloverStrategy max="30"/>
        </RollingFile>

    </Appenders>


    <!-- ============================================================
         LOGGERS
         ============================================================ -->
    <Loggers>

        <!-- Your Application Logs -->
        <Logger name="com.capg.jobportal" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Logger>

        <!-- Spring Logs -->
        <Logger name="org.springframework" level="INFO" additivity="false">
            <AppenderRef ref="Console"/>
        </Logger>

        <!-- Root Logger -->
        <Root level="INFO">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="File"/>
        </Root>

    </Loggers>

</Configuration>